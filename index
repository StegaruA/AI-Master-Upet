// =====================================================
// MODEL N-GRAM (JavaScript)
// =====================================================

function tokenize(text) {
  return text.toLowerCase()
    .replace(/[^\wșțăîâșțăîâ\s]/g, ' ')
    .split(/\s+/)
    .filter(w => w.length >= 2);
}

function buildNgramModel(tokens, n) {
  const model = {};
  for (let i = 0; i < tokens.length - n; i++) {
    const context = tokens.slice(i, i + n - 1).join(' ');
    const next = tokens[i + n - 1];
    if (!model[context]) model[context] = [];
    model[context].push(next);
  }
  return model;
}

function generateText(model, n, length, seedTopic) {
  const keys = Object.keys(model);
  if (keys.length === 0) return [];

  let contextKey;
  if (seedTopic) {
    const matching = keys.filter(k => k.includes(seedTopic.toLowerCase()));
    contextKey = matching.length > 0
      ? matching[Math.floor(Math.random() * matching.length)]
      : keys[Math.floor(Math.random() * keys.length)];
  } else {
    contextKey = keys[Math.floor(Math.random() * keys.length)];
  }

  const words = contextKey.split(' ');
  const chain = [{ words: [...words], type: 'context' }];

  for (let i = 0; i < length; i++) {
    const ctx = words.slice(-(n - 1)).join(' ');
    const continuations = model[ctx];
    if (!continuations || continuations.length === 0) break;
    const next = continuations[Math.floor(Math.random() * continuations.length)];
    words.push(next);
    chain.push({ words: [next], type: 'predicted' });
  }

  return { words, chain };
}

// =====================================================
// STATE
// =====================================================
let currentN = 3;
let currentTopic = '';
const tokens = tokenize(CORPUS);
let models = {
  2: buildNgramModel(tokens, 2),
  3: buildNgramModel(tokens, 3),
  4: buildNgramModel(tokens, 4),
};

// Init stats
document.getElementById('statContexts').textContent = Object.keys(models[3]).length;
document.getElementById('statVocab').textContent = new Set(tokens).size;

// =====================================================
// UI INTERACTIONS
// =====================================================

document.querySelectorAll('.n-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.n-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    currentN = parseInt(btn.dataset.n);
    document.getElementById('statContexts').textContent = Object.keys(models[currentN]).length;
  });
});

document.getElementById('lengthSlider').addEventListener('input', function() {
  document.getElementById('lengthVal').textContent = this.value;
});

document.querySelectorAll('.pill').forEach(pill => {
  pill.addEventListener('click', () => {
    document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
    pill.classList.add('active');
    currentTopic = pill.dataset.topic;
  });
});

// =====================================================
// GENERATE
// =====================================================

function generate() {
  const length = parseInt(document.getElementById('lengthSlider').value);
  const model = models[currentN];
  const result = generateText(model, currentN, length, currentTopic);

  if (!result || result.words.length === 0) return;

  const box = document.getElementById('outputBox');
  box.classList.add('active');
  box.innerHTML = '<span class="cursor"></span>';

  // Animate words
  result.words.forEach((word, i) => {
    setTimeout(() => {
      const span = document.createElement('span');
      span.className = 'word';
      span.style.animationDelay = '0ms';
      span.textContent = (i === 0 ? '' : ' ') + word;
      box.insertBefore(span, box.querySelector('.cursor'));
    }, i * 80);
  });

  // Remove cursor after done
  setTimeout(() => {
    const cursor = box.querySelector('.cursor');
    if (cursor) cursor.remove();
    box.classList.remove('active');
  }, result.words.length * 80 + 500);

  // Update stats
  document.getElementById('statWords').textContent = result.words.length;
  document.getElementById('statContexts').textContent = Object.keys(model).length;
  document.getElementById('statVocab').textContent = new Set(tokens).size;

  // Update n-gram chain visualization (last 6 steps)
  const chainEl = document.getElementById('ngramChain');
  chainEl.innerHTML = '';
  const steps = result.chain.slice(-8);
  steps.forEach((step, i) => {
    step.words.forEach(w => {
      const token = document.createElement('span');
      token.className = 'ngram-token ' + (i < steps.length - 3 ? 'context' : 'predicted');
      token.textContent = w;
      chainEl.appendChild(token);
    });
    if (i < steps.length - 1) {
      const arrow = document.createElement('span');
      arrow.className = 'ngram-arrow';
      arrow.textContent = '→';
      chainEl.appendChild(arrow);
    }
  });
}
</script>
